{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shardmind.local/schemas/note.schema.json",
  "title": "ShardMind Note",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "created_at",
    "updated_at",
    "sections"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^note-[0-9a-f]{32}$"
    },
    "type": {
      "const": "note"
    },
    "title": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "description": "Obsidian tags: ASCII letters, digits, _, -, / for nesting; at least one non-digit; no spaces. ShardMind validates on write."
      },
      "default": []
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "created_from": {
          "type": "string"
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "sections": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "content"
      ],
      "properties": {
        "content": {
          "type": "string",
          "default": ""
        }
      }
    }
  }
}
